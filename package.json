  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "svelte": "^5.19.0",
    "svelte-check": "^4.1.4",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vite-plugin-static-copy": "^2.2.0"
  }
