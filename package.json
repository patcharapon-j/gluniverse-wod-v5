{
  "name": "gluniverse-wod-v5",
  "version": "0.0.0",
  "description": "A modern, unofficial Foundry VTT game system for the World of Darkness 5th Edition family of games.",
  "type": "module",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "vite build",
    "watch": "vite build --watch",
